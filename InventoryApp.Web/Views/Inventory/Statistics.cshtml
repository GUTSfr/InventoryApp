@model InventoryApp.Web.Models.InventoryStatisticsViewModel

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Statistics — @Model.InventoryTitle</h2>
    <a asp-action="Details" asp-route-id="@Model.InventoryId" class="btn btn-secondary">Back</a>
</div>

<div class="row">
    <div class="col-md-6">
        <table class="table">
            <tr>
                <th>Total Items</th>
                <td>@Model.TotalItems</td>
            </tr>
        </table>

        @foreach (var stat in Model.NumericStats)
        {
            <h5>@stat.FieldTitle</h5>
            <table class="table">
                <tr>
                    <th>Average</th>
                    <td>@stat.Average?.ToString("F2")</td>
                </tr>
                <tr>
                    <th>Min</th>
                    <td>@stat.Min</td>
                </tr>
                <tr>
                    <th>Max</th>
                    <td>@stat.Max</td>
                </tr>
            </table>
        }

        @foreach (var stat in Model.StringStats)
        {
            <h5>@stat.FieldTitle — Most Used Values</h5>
            <table class="table">
                <thead>
                    <tr>
                        <th>Value</th>
                        <th>Count</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var val in stat.TopValues)
                    {
                        <tr>
                            <td>@val.Value</td>
                            <td>@val.Count</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>