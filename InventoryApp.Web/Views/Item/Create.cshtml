@model InventoryApp.Web.Models.ItemViewModel

<h2>Add Item</h2>

<div class="row">
    <div class="col-md-6">
        <form asp-action="Create" method="post">
            <input asp-for="InventoryId" type="hidden" />
            <input asp-for="RowVersion" type="hidden" />

            <div asp-validation-summary="All" class="text-danger"></div>

            @foreach (var field in Model.Fields)
            {
                <div class="mb-3">
                    <label class="form-label">@field.Title</label>

                    @if (field.Type == "SingleLineText" || field.Type == "Link")
                    {
                        <input name="@field.SlotName" class="form-control" title="@field.Description" />
                    }
                    else if (field.Type == "MultiLineText")
                    {
                        <textarea name="@field.SlotName" class="form-control" rows="3" title="@field.Description"></textarea>
                    }
                    else if (field.Type == "Numeric")
                    {
                        <input name="@field.SlotName" type="number" step="any" class="form-control" title="@field.Description" />
                    }
                    else if (field.Type == "Boolean")
                    {
                        <input name="@field.SlotName" type="checkbox" class="form-check-input" title="@field.Description" />
                    }
                </div>
            }

            <button type="submit" class="btn btn-primary">Save</button>
            <a asp-controller="Inventory" asp-action="Details" asp-route-id="@Model.InventoryId" class="btn btn-secondary">Cancel</a>
        </form>
    </div>
</div>      